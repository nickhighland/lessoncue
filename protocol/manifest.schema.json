{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lessoncue.org/protocol/v1/manifest.schema.json",
  "title": "LessonCue screen manifest",
  "type": "object",
  "required": ["apiVersion", "manifestVersion", "generatedAt", "screen", "signage", "signageSchedule", "playlists"],
  "properties": {
    "apiVersion": { "const": 1 },
    "manifestVersion": { "type": "integer", "minimum": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "screen": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "volunteerMode": { "type": "boolean", "default": true }
      }
    },
    "playlists": {
      "type": "array",
      "items": { "$ref": "#/$defs/playlist" }
    },
    "signage": { "type": "array", "items": { "$ref": "#/$defs/signage" } },
    "signageSchedule": { "type": "array", "items": { "$ref": "#/$defs/signage" } }
  },
  "$defs": {
    "signage": {
      "type": "object",
      "required": ["id", "name", "mode", "priority", "message", "backgroundColor", "textColor"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "mode": { "enum": ["scheduled", "idle", "emergency"] },
        "priority": { "type": "integer", "minimum": 0, "maximum": 100 },
        "message": { "type": "string" },
        "backgroundColor": { "type": "string" },
        "textColor": { "type": "string" },
        "mediaAssetId": { "type": ["string", "null"] },
        "mediaUrl": { "type": ["string", "null"] },
        "media": { "anyOf": [{ "$ref": "#/$defs/item" }, { "type": "null" }] },
        "startsAt": { "type": ["string", "null"], "format": "date-time" },
        "endsAt": { "type": ["string", "null"], "format": "date-time" },
        "recurrence": { "enum": ["once", "daily", "weekly"] },
        "nextChangeAt": { "type": ["string", "null"], "format": "date-time" },
        "ready": { "type": "boolean" },
        "readiness": { "enum": ["ready", "preparing", "failed", "missing"] }
      }
    },
    "playlist": {
      "type": "object",
      "required": ["playlistId", "title", "version", "items"],
      "properties": {
        "playlistId": { "type": "string" },
        "title": { "type": "string" },
        "version": { "type": "integer", "minimum": 1 },
        "availableFrom": { "type": ["string", "null"], "format": "date-time" },
        "expiresAt": { "type": ["string", "null"], "format": "date-time" },
        "designatedStartAt": { "type": ["string", "null"], "format": "date-time" },
        "preRollStartsAt": { "type": ["string", "null"], "format": "date-time" },
        "countdown": { "$ref": "#/$defs/countdown" },
        "preRoll": { "$ref": "#/$defs/preRoll" },
        "items": { "type": "array", "items": { "$ref": "#/$defs/item" } }
      }
    },
    "countdown": {
      "type": ["object", "null"],
      "required": ["enabled", "itemId", "durationMs", "item"],
      "properties": {
        "enabled": { "type": "boolean" },
        "itemId": { "type": "string" },
        "durationMs": { "type": "integer", "minimum": 1 },
        "startAt": { "type": ["string", "null"], "format": "date-time" },
        "item": { "$ref": "#/$defs/item" }
      }
    },
    "preRoll": {
      "type": ["object", "null"],
      "required": ["enabled", "loop", "items"],
      "properties": {
        "enabled": { "type": "boolean" },
        "loop": { "type": "boolean", "const": true },
        "items": { "type": "array", "items": { "$ref": "#/$defs/item" } }
      }
    },
    "item": {
      "type": "object",
      "required": ["itemId", "type", "title", "endBehavior", "offlineEligible"],
      "properties": {
        "itemId": { "type": "string" },
        "mediaId": { "type": ["string", "null"] },
        "type": { "enum": ["video", "audio", "image", "liveStream", "external", "web"] },
        "title": { "type": "string" },
        "downloadUrl": { "type": ["string", "null"] },
        "playbackUrl": { "type": ["string", "null"] },
        "contentType": { "type": ["string", "null"] },
        "fileExtension": { "type": ["string", "null"], "pattern": "^[a-zA-Z0-9]{0,8}$" },
        "compatibilityStatus": { "type": ["string", "null"], "enum": ["pending", "converting", "native", "ready", "failed", "not-needed", null] },
        "requestedProfile": { "type": ["string", "null"], "enum": ["native", "h264-1080", "h264-720", "h264-480", null] },
        "selectedProfile": { "type": ["string", "null"], "enum": ["native", "h264-1080", "h264-720", "h264-480", null] },
        "transcodeStatus": { "type": ["string", "null"], "enum": ["pending", "converting", "ready", "failed", "not-generated", "not-needed", null] },
        "sha256": { "type": ["string", "null"] },
        "sizeBytes": { "type": ["integer", "null"], "minimum": 0 },
        "durationMs": { "type": ["integer", "null"], "minimum": 0 },
        "startMs": { "type": "integer", "minimum": 0, "default": 0 },
        "endMs": { "type": ["integer", "null"], "minimum": 0 },
        "volumePercent": { "type": "integer", "minimum": 0, "maximum": 150, "default": 100 },
        "imageDurationSeconds": { "type": ["integer", "null"], "minimum": 1 },
        "endBehavior": { "enum": ["advance", "pause", "loop", "menu", "stop"] },
        "allowSkip": { "type": "boolean", "default": true },
        "offlineEligible": { "type": "boolean" },
        "sourceKind": { "type": ["string", "null"] },
        "sourceUrl": { "type": ["string", "null"] },
        "linkKind": { "type": ["string", "null"] },
        "notes": { "type": "string" },
        "fadeInMs": { "type": "integer", "minimum": 0 },
        "fadeOutMs": { "type": "integer", "minimum": 0 },
        "normalizeAudio": { "type": "boolean" },
        "cuePoints": {
          "type": "array",
          "maxItems": 50,
          "items": { "$ref": "#/$defs/cuePoint" }
        }
      }
    },
    "cuePoint": {
      "type": "object",
      "required": ["name", "positionMs"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 80 },
        "positionMs": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
