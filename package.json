{
  "name": "lessoncue",
  "version": "0.25.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "npm run dev:admin",
    "build": "npm run build:admin",
    "dev:admin": "vite --config web-admin/vite.config.ts",
    "build:admin": "vite build --config web-admin/vite.config.ts",
    "typecheck:admin": "tsc -p web-admin/tsconfig.json",
    "test": "npm run typecheck:admin && npm run build:admin",
    "test:e2e": "playwright test",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@microsoft/signalr": "^9.0.6",
    "qrcode": "^1.5.4",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@playwright/test": "^1.61.1",
    "@types/node": "22.19.19",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "7.0.1",
    "globals": "16.5.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.0",
    "vite": "8.1.4"
  },
  "type": "module"
}
