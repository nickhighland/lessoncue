<?xml version="1.0" standalone="no"?>
<!DOCTYPE service-group SYSTEM "avahi-service.dtd">
<service-group>
  <name replace-wildcards="yes">LessonCue on %h</name>
  <service>
    <type>_lessoncue._tcp</type>
    <port>80</port>
    <txt-record>apiVersion=1</txt-record>
    <txt-record>secure=false</txt-record>
    <txt-record>port=80</txt-record>
  </service>
</service-group>
